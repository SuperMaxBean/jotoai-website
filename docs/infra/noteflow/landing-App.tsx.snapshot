// --- Main App ---

const LandingPage = () => {
  const { hash } = useLocation();
  const { t, tArray } = useTranslation();

  useEffect(() => {
    if (hash) {
      const id = hash.replace('#', '');
      const element = document.getElementById(id);
      if (element) {
        element.scrollIntoView({ behavior: 'smooth' });
      }
    } else {
      window.scrollTo(0, 0);
    }
  }, [hash]);

  return (
    <>
      <Hero />
      <StatBar />
      <CoreDifferentiators />
      <ThinBanner />

      {/* Feature Deep Dives */}
      <FeatureDeepDive
        id="features"
        label={t('featureDeepDive.f1Label')}
        title={t('featureDeepDive.f1Title')}
        body={t('featureDeepDive.f1Body')}
        points={tArray('featureDeepDive.f1Points')}
        visual={
          <div className="grid grid-cols-2 gap-4 w-full max-w-[440px]">
            {[
              { title: t('featureDeepDive.f1Card1'), color: 'bg-[#dde8f8]', icon: <BarChart3 size={24} />, members: 3 },
              { title: t('featureDeepDive.f1Card2'), color: 'bg-[#fdf3d0]', icon: <FileText size={24} /> },
              { title: t('featureDeepDive.f1Card3'), color: 'bg-[#e0f0d8]', icon: <Zap size={24} />, members: 5 },
              { title: t('featureDeepDive.f1Card4'), color: 'bg-[#ede8f8]', icon: <Shield size={24} /> }
            ].map((card, i) => (
              <div key={i} className="bg-white border border-border-base rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all">
                <div className={`h-24 ${card.color} flex items-center justify-center text-primary-green/80`}>
                  {card.icon}
                </div>
                <div className="p-3">
                  <div className="text-[13px] font-bold truncate">{card.title}</div>
                  <div className="flex items-center justify-between mt-1">
                    <span className="text-[10px] text-text-muted">{t('featureDeepDive.f1UpdatedAgo')}</span>
                    {card.members && (
                      <div className="flex items-center gap-1 px-1.5 py-0.5 bg-green-bg-tint rounded-md text-[9px] font-bold text-primary-green">
                        <Users size={8} /> {card.members}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        }
      />

      <FeatureDeepDive
        label={t('featureDeepDive.f2Label')}
        title={t('featureDeepDive.f2Title')}
        body={t('featureDeepDive.f2Body')}
        points={tArray('featureDeepDive.f2Points')}
        reverse
        visual={
          <div className="w-full max-w-[400px] flex flex-col gap-3">
            {[
              { step: 1, text: t('featureDeepDive.f2Step1'), active: true },
              { step: 2, text: t('featureDeepDive.f2Step2'), active: false },
              { step: 3, text: t('featureDeepDive.f2Step3'), active: true, badge: t('featureDeepDive.f2Step3Badge') },
              { step: 4, text: t('featureDeepDive.f2Step4'), active: false },
              { step: 5, text: t('featureDeepDive.f2Step5'), active: 'full' }
            ].map((step, i) => (
              <div 
                key={i} 
                className={`flex items-center justify-between p-4 rounded-xl border transition-all ${
                  step.active === 'full' ? 'bg-primary-green border-primary-green text-white' : 
                  step.active ? 'bg-green-bg-tint border-green-border text-primary-green' : 
                  'bg-surface border-border-base text-text-secondary'
                }`}
              >
                <div className="flex items-center gap-3">
                  <div className={`w-6 h-6 rounded-full flex items-center justify-center text-[12px] font-bold ${
                    step.active === 'full' ? 'bg-white text-primary-green' : 
                    step.active ? 'bg-primary-green text-white' : 
                    'bg-border-base text-text-muted'
                  }`}>
                    {step.step}
                  </div>
                  <span className="text-[14px] font-semibold">{step.text}</span>
                </div>
                {step.badge && (
                  <div className="px-2 py-0.5 bg-primary-green text-white text-[10px] font-bold rounded-full">
                    {step.badge}
                  </div>
                )}
                {step.active === 'full' && <CheckCircle2 size={18} />}
              </div>
            ))}
          </div>
        }
      />

      <FeatureDeepDive
        label={t('featureDeepDive.f3Label')}
        title={t('featureDeepDive.f3Title')}
        body={t('featureDeepDive.f3Body')}
        points={tArray('featureDeepDive.f3Points')}
        visual={
          <div className="w-full max-w-[440px] bg-white border border-border-base rounded-2xl overflow-hidden shadow-sm">
            <div className="p-3 border-b border-border-base bg-surface text-[12px] font-bold text-text-muted">{t('featureDeepDive.f3ToolsHeader')}</div>
            <div className="flex flex-col">
              {[
                { name: t('featureDeepDive.f3Tool1Name'), desc: t('featureDeepDive.f3Tool1Desc'), icon: <FileText size={20} />, status: 'Ready' },
                { name: t('featureDeepDive.f3Tool2Name'), desc: t('featureDeepDive.f3Tool2Desc'), icon: <MessageSquare size={20} />, status: 'Ready' },
                { name: t('featureDeepDive.f3Tool3Name'), icon: <Layout size={20} />, desc: t('featureDeepDive.f3Tool3Desc'), status: 'Ready' },
                { name: t('featureDeepDive.f3Tool4Name'), desc: t('featureDeepDive.f3Tool4Desc'), icon: <Headphones size={20} />, status: 'Soon' },
                { name: t('featureDeepDive.f3Tool5Name'), desc: t('featureDeepDive.f3Tool5Desc'), icon: <Presentation size={20} />, status: 'Soon' }
              ].map((item, i) => (
                <div key={i} className="flex items-center justify-between p-4 border-b border-border-base last:border-b-0 hover:bg-hover-surface transition-colors">
                  <div className="flex items-center gap-3">
                    <div className="text-primary-green/80">{item.icon}</div>
                    <div>
                      <div className="text-[14px] font-bold text-text-primary">{item.name}</div>
                      <div className="text-[12px] text-text-muted">{item.desc}</div>
                    </div>
                  </div>
                  <div className={`px-2 py-0.5 rounded-[4px] text-[10px] font-bold ${
                    item.status === 'Ready' ? 'bg-green-bg-tint text-primary-green border border-green-border' : 
                    'bg-hover-surface text-text-muted border border-border-base'
                  }`}>
                    {item.status === 'Ready' ? t('featureDeepDive.f3StatusReady') : t('featureDeepDive.f3StatusSoon')}
                  </div>
                </div>
              ))}
            </div>
          </div>
        }
      />

      <FeatureDeepDive
        label={t('featureDeepDive.f4Label')}
        title={t('featureDeepDive.f4Title')}
        body={t('featureDeepDive.f4Body')}
        points={tArray('featureDeepDive.f4Points')}
        reverse
        visual={
          <div className="w-full max-w-[440px] flex flex-col gap-4">
            <div className="bg-white border border-border-base rounded-2xl overflow-hidden shadow-sm">
              <div className="p-4 border-b border-border-base bg-surface flex justify-between items-center">
                <span className="text-[12px] font-bold text-text-muted uppercase tracking-wider">{t('featureDeepDive.f4MarketplaceHeader')}</span>
                <div className="flex items-center gap-1 px-2 py-1 bg-green-bg-tint rounded-md text-[10px] font-bold text-primary-green">
                  <Globe size={10} /> {t('featureDeepDive.f4PublicNotebooks')}
                </div>
              </div>
              <div className="flex flex-col">
                {[
                  { title: t('featureDeepDive.f4Item1Title'), author: t('featureDeepDive.f4Item1Author'), status: t('featureDeepDive.f4Item1Status'), statusKey: 'Joined', members: 42, color: 'bg-[#dde8f8]', icon: <BarChart3 size={20} /> },
                  { title: t('featureDeepDive.f4Item2Title'), author: t('featureDeepDive.f4Item2Author'), status: t('featureDeepDive.f4Item2Status'), statusKey: 'Request Access', members: 128, color: 'bg-[#e0f0d8]', icon: <Zap size={20} /> },
                  { title: t('featureDeepDive.f4Item3Title'), author: t('featureDeepDive.f4Item3Author'), status: t('featureDeepDive.f4Item3Status'), statusKey: 'Pending Approval', members: 15, color: 'bg-[#ede8f8]', icon: <Shield size={20} /> }
                ].map((item, i) => (
                  <div key={i} className="flex items-center justify-between p-4 border-b border-border-base last:border-b-0 hover:bg-hover-surface transition-colors">
                    <div className="flex items-center gap-3">
                      <div className={`w-10 h-10 rounded-lg ${item.color} flex items-center justify-center text-primary-green/80`}>
                        {item.icon}
                      </div>
                      <div>
                        <div className="text-[14px] font-bold text-text-primary">{item.title}</div>
                        <div className="text-[12px] text-text-muted">{t('featureDeepDive.f4ByLabel')} {item.author} · {item.members} {t('featureDeepDive.f4MembersLabel')}</div>
                      </div>
                    </div>
                    <button className={`px-3 py-1.5 rounded-[6px] text-[11px] font-bold transition-all ${
                      item.statusKey === 'Joined' ? 'bg-surface border border-border-base text-text-secondary' :
                      item.statusKey === 'Pending Approval' ? 'bg-[#fff8e6] border border-[#f5d480] text-[#b28415]' :
                      'bg-primary-green text-white hover:bg-primary-green-hover'
                    }`}>
                      {item.status}
                    </button>
                  </div>
                ))}
              </div>
            </div>
          </div>
        }
      />

      <FeatureDeepDive
        label={t('featureDeepDive.f5Label')}
        title={t('featureDeepDive.f5Title')}
        body={t('featureDeepDive.f5Body')}
        points={tArray('featureDeepDive.f5Points')}
        visual={
          <div className="w-full max-w-[440px] bg-white border border-border-base rounded-2xl overflow-hidden shadow-mockup">
            <div className="p-4 border-b border-border-base flex items-center justify-between bg-surface">
              <div className="flex items-center gap-2">
                <div className="w-6 h-6 bg-primary-green rounded flex items-center justify-center text-white text-[10px] font-bold">NF</div>
                <span className="text-[12px] font-bold">{t('featureDeepDive.f5Chat')}</span>
              </div>
              <div className="flex items-center gap-2 px-2 py-1 bg-white border border-border-base rounded-full">
                <Globe size={12} className="text-primary-green" />
                <span className="text-[10px] font-bold text-text-secondary">{t('featureDeepDive.f5WebSearchOn')}</span>
              </div>
            </div>
            <div className="p-6 flex flex-col gap-4">
              <div className="flex gap-2">
                <div className="px-2 py-1 bg-green-bg-tint border border-green-border rounded-md text-[10px] font-bold text-primary-green flex items-center gap-1">
                  <FileText size={10} /> {t('featureDeepDive.f5InternalDoc')}
                </div>
                <div className="px-2 py-1 bg-[#dde8f8] border border-[#1a5cb8]/20 rounded-md text-[10px] font-bold text-[#1a5cb8] flex items-center gap-1">
                  <Globe size={10} /> {t('featureDeepDive.f5WebSource')}
                </div>
              </div>
              <div className="space-y-2">
                <div className="h-3 w-full bg-hover-surface rounded" />
                <div className="h-3 w-full bg-hover-surface rounded" />
                <div className="h-3 w-2/3 bg-hover-surface rounded" />
              </div>
            </div>
          </div>
        }
      />

      <FeatureDeepDive
        label={
          <div className="flex items-center gap-2">
            {t('featureDeepDive.f6LabelPrefix')} <span className="px-1.5 py-0.5 bg-hover-surface text-text-muted border border-border-base rounded-[4px] text-[10px] font-bold">{t('featureDeepDive.f6LabelBeta')}</span>
          </div>
        }
        title={t('featureDeepDive.f6Title')}
        body={t('featureDeepDive.f6Body')}
        points={tArray('featureDeepDive.f6Points')}
        reverse
        visual={
          <div className="w-full max-w-[440px] flex flex-col gap-4">
            <div className="bg-white border border-border-base rounded-xl p-3 flex items-center justify-between shadow-sm">
              <div className="flex items-center gap-3">
                <Mic size={18} className="text-primary-green" />
                <div>
                  <div className="text-[12px] font-bold">Weekly_Sync.mp3</div>
                  <div className="text-[10px] text-text-muted">12.4 MB · 45:02</div>
                </div>
              </div>
              <div className="px-2 py-0.5 bg-green-bg-tint text-primary-green text-[10px] font-bold rounded-full">
                {t('featureDeepDive.f6Processing')}
              </div>
            </div>
            <div className="flex justify-between px-2">
              <div className="flex flex-col items-center gap-1">
                <div className="w-2 h-2 rounded-full bg-primary-green" />
                <span className="text-[9px] text-text-muted">{t('featureDeepDive.f6Upload')}</span>
              </div>
              <div className="flex-1 h-[1px] bg-primary-green mt-1 mx-2" />
              <div className="flex flex-col items-center gap-1">
                <div className="w-2 h-2 rounded-full bg-primary-green animate-ping" />
                <span className="text-[9px] text-text-muted">{t('featureDeepDive.f6ASR')}</span>
              </div>
              <div className="flex-1 h-[1px] bg-border-base mt-1 mx-2" />
              <div className="flex flex-col items-center gap-1">
                <div className="w-2 h-2 rounded-full bg-border-base" />
                <span className="text-[9px] text-text-muted">{t('featureDeepDive.f6Analyze')}</span>
              </div>
            </div>
            <div className="bg-green-bg-tint border border-green-border rounded-xl p-4">
              <div className="flex items-center gap-2 mb-3">
                <span className="text-[11px] font-bold text-primary-green">Speaker 1 (Alex)</span>
                <span className="text-[10px] text-text-muted">0:12</span>
              </div>
              <div className="h-3 w-full bg-primary-green/10 rounded mb-2" />
              <div className="h-3 w-3/4 bg-primary-green/10 rounded" />
            </div>
          </div>
        }
      />

      <UseCases />
      <ComparisonTable />
      <CTASection />
      <ContactSection />
    </>
  );
};

export default function App() {
  return (
    <Router>
      <div className="min-h-screen">
        <Navbar />
        
        <main>
          <Routes>
            <Route path="/" element={<LandingPage />} />
            <Route path="/features" element={<FeaturesPage />} />
            <Route path="/use-cases" element={<UseCasesPage />} />
            <Route path="/contact" element={<ContactPage />} />
            <Route path="/blog" element={<BlogPage />} />
            <Route path="/blog/:id" element={<BlogPostPage />} />
            <Route path="/privacy" element={<PrivacyPage />} />
          </Routes>
        </main>

        <Footer />
      </div>
    </Router>
  );
}
