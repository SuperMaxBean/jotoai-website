      <h2 className="text-[42px] font-extrabold tracking-[-0.025em] leading-[1.15] text-text-primary mb-4">{t('comparison.sectionTitle')}</h2>
      <p className="text-[17px] text-text-secondary max-w-[700px]">{t('comparison.sectionSubtitle')}</p>
    </motion.div>

    <motion.div
      initial={{ opacity: 0, scale: 0.98 }}
      whileInView={{ opacity: 1, scale: 1 }}
      viewport={{ once: true }}
      className="border border-border-base rounded-[14px] overflow-hidden shadow-sm"
    >
      <table className="w-full text-left border-collapse">
        <thead className="bg-surface border-b border-border-base">
          <tr>
            <th className="px-6 py-4 text-[13px] font-bold text-text-primary">{t('comparison.colFeature')}</th>
            <th className="px-6 py-4 text-[13px] font-bold text-primary-green text-center">{t('comparison.colNoteFlow')}</th>
            <th className="px-6 py-4 text-[13px] font-bold text-text-primary text-center">{t('comparison.colNotebookLM')}</th>
          </tr>
        </thead>
        <tbody>
          {[
            { name: t('comparison.row1'), nf: true, nblm: false },
            { name: t('comparison.row2'), nf: true, nblm: false },
            { name: t('comparison.row3'), nf: true, nblm: false },
            { name: t('comparison.row4'), nf: true, nblm: false },
            { name: t('comparison.row5'), nf: true, nblm: false },
            { name: t('comparison.row6'), nf: true, nblm: false },
            { name: t('comparison.row7'), nf: true, nblm: true },
            { name: t('comparison.row8'), nf: true, nblm: true },
            { name: t('comparison.row9'), nf: 'soon', nblm: true },
            { name: t('comparison.row10'), nf: 'soon', nblm: true },
            { name: t('comparison.row11'), nf: 'soon', nblm: false },
            { name: t('comparison.row12'), nf: 'soon', nblm: false }
          ].map((row, i) => (
            <tr key={i} className="border-b border-border-base last:border-b-0 hover:bg-surface transition-colors">
              <td className="px-6 py-3.5 text-[14px] text-text-secondary">{row.name}</td>
              <td className="px-6 py-3.5 text-center">
                {row.nf === true ? <Check size={18} className="text-primary-green mx-auto font-bold" /> :
                 row.nf === 'soon' ? <span className="px-2 py-0.5 bg-hover-surface border border-border-base rounded-[4px] text-[11px] font-semibold text-text-muted">{t('comparison.comingSoon')}</span> :
                 <X size={18} className="text-text-muted/40 mx-auto" />}
              </td>
              <td className="px-6 py-3.5 text-center">
                {row.nblm === true ? <Check size={18} className="text-primary-green mx-auto font-bold" /> : 
                 <X size={18} className="text-text-muted/40 mx-auto" />}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </motion.div>
  </section>
  );
};

