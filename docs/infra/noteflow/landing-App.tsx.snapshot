            <button className="w-full py-4 bg-primary-green text-white font-bold rounded-xl hover:bg-primary-green-hover transition-all shadow-md flex items-center justify-center gap-2 mt-4">
              {t('contactSection.sendMessage')} <ArrowRight size={18} />
