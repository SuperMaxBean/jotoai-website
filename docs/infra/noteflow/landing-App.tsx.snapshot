    >
      <span className={`px-2.5 py-1 rounded-full transition-all ${language === 'en' ? 'bg-primary-green text-white' : 'text-text-secondary'}`}>
        EN
      </span>
      <span className={`px-2.5 py-1 rounded-full transition-all ${language === 'zh' ? 'bg-primary-green text-white' : 'text-text-secondary'}`}>
