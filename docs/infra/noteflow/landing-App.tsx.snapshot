const Typewriter = ({ text, speed = 20, onComplete }: { text: string, speed?: number, onComplete?: () => void }) => {
  const [displayed, setDisplayed] = React.useState('');
  const onCompleteRef = React.useRef(onComplete);
  
  useEffect(() => {
    onCompleteRef.current = onComplete;
  }, [onComplete]);

  useEffect(() => {
    let i = 0;
    setDisplayed('');
    const timer = setInterval(() => {
      if (i < text.length) {
        setDisplayed(text.substring(0, i + 1));
        i++;
      } else {
        clearInterval(timer);
        if (onCompleteRef.current) onCompleteRef.current();
      }
    }, speed);
    return () => clearInterval(timer);
  }, [text, speed]);

  return <span>{displayed}</span>;
};

const AnimatedResponse = () => {
  const [step, setStep] = React.useState(0);
  const { t } = useTranslation();

  useEffect(() => {
    const timer = setTimeout(() => setStep(1), 800);
    const interval = setInterval(() => {
      setStep(0);
      setTimeout(() => setStep(1), 800);
    }, 12000);

    return () => {
      clearTimeout(timer);
      clearInterval(interval);
    };
  }, []);

  return (
    <div className="flex flex-col gap-3 max-w-[80%]">
      <div className="text-[14px] leading-relaxed">
        {step >= 1 ? (
          <div>
            <Typewriter
              text={t('animatedResponse.intro')}
              speed={15}
              onComplete={() => setStep(2)}
            />
          </div>
        ) : <div className="h-5" />}

        <ul className="list-disc ml-4 mt-2 flex flex-col gap-1">
          {step >= 2 && (
            <li>
              <Typewriter
                text={t('animatedResponse.point1')}
                speed={15}
                onComplete={() => setStep(3)}
              />
            </li>
          )}
          {step >= 3 && (
            <li>
              <Typewriter
                text={t('animatedResponse.point2')}
                speed={15}
                onComplete={() => setStep(4)}
              />
            </li>
          )}
          {step >= 4 && (
            <li>
              <Typewriter
                text={t('animatedResponse.point3')}
                speed={15}
                onComplete={() => setStep(5)}
              />
            </li>
          )}
        </ul>
      </div>
      {step >= 5 && (
        <motion.div 
          initial={{ opacity: 0, y: 5 }} 
          animate={{ opacity: 1, y: 0 }} 
          className="flex flex-wrap gap-2"
        >
          <div className="flex items-center gap-1 px-2 py-1 bg-green-bg-tint border border-green-border rounded-md text-[11px] font-bold text-primary-green">
            <FileText size={10} /> Q4_Report.pdf (p. 12)
          </div>
          <div className="flex items-center gap-1 px-2 py-1 bg-green-bg-tint border border-green-border rounded-md text-[11px] font-bold text-primary-green">
            <FileText size={10} /> Meeting_Notes.docx (p. 2)
          </div>
        </motion.div>
      )}
    </div>
  );
};

